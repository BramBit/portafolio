---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = 'Brayan Mercado — Backend Engineer',
  description = 'Backend Engineer con 2.5 años en producción. Especializado en Arquitectura Hexagonal, DDD, Node.js/TypeScript y pipelines de IA. Disponible para nuevas oportunidades.',
  image = '/og-image.png',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = Astro.props;

const ogImage = new URL(image, Astro.site).href;
const siteName = 'Brayan Mercado — Backend Engineer';
---

<!doctype html>
<html lang="es">
  <head>
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const prefersDark = matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Brayan Mercado" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Brayan Mercado — Backend Engineer" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Brayan Mercado — Backend Engineer" />

    <!-- Icons & PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#5558e3" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: Person -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Brayan Mercado",
        "alternateName": "Brayan Mercado San Martín",
        "url": "https://brayanmercado.com",
        "image": "https://brayanmercado.com/bram-profile.png",
        "jobTitle": "Backend Engineer",
        "description": "Backend Engineer con 2.5 años en producción. Especializado en Arquitectura Hexagonal, DDD, Node.js/TypeScript y pipelines de IA.",
        "email": "brayan.msanmartin@gmail.com",
        "telephone": "+573013702999",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "CO",
          "addressLocality": "Colombia"
        },
        "sameAs": [
          "https://www.linkedin.com/in/brayan-mercado-sanmartin",
          "https://github.com/BramBit"
        ],
        "knowsAbout": [
          "Node.js", "TypeScript", "PHP", "Laravel", "PostgreSQL",
          "Arquitectura Hexagonal", "Domain-Driven Design", "RAG",
          "RabbitMQ", "Docker", "FastAPI"
        ],
        "worksFor": {
          "@type": "Organization",
          "name": "Alaska Tech"
        }
      }
    </script>

    <!-- JSON-LD: WebSite -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Brayan Mercado — Backend Engineer",
        "url": "https://brayanmercado.com",
        "description": "Portafolio profesional de Brayan Mercado, Backend Engineer especializado en Arquitectura Hexagonal y sistemas de IA.",
        "inLanguage": "es-CO",
        "author": {
          "@type": "Person",
          "name": "Brayan Mercado"
        }
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg-primary: #f5f6ff;
    --bg-secondary: #eceefa;
    --bg-card: #ffffff;
    --bg-card-hover: #f8f9ff;
    --border: #dde0f5;
    --border-hover: #b8bde6;
    --accent: #5558e3;
    --accent-glow: rgba(85, 88, 227, 0.12);
    --accent-light: #7478f0;
    --accent-dim: rgba(85, 88, 227, 0.3);
    --text-primary: #0d0f28;
    --text-secondary: #4c4f78;
    --text-muted: #9496be;
    --green: #059669;
    --green-bg: rgba(5, 150, 105, 0.07);
    --green-border: rgba(5, 150, 105, 0.2);
    --shadow-sm: 0 1px 3px rgba(20, 25, 100, 0.07), 0 2px 6px rgba(20, 25, 100, 0.05);
    --shadow-md: 0 4px 16px rgba(20, 25, 100, 0.1), 0 2px 6px rgba(20, 25, 100, 0.06);
    --nav-bg: rgba(245, 246, 255, 0.92);
    --nav-mobile-bg: rgba(245, 246, 255, 0.98);
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
    --max-width: 1080px;
  }

  [data-theme='dark'] {
    --bg-primary: #0d0f1d;
    --bg-secondary: #131629;
    --bg-card: #1a1d2e;
    --bg-card-hover: #1f2236;
    --border: #252840;
    --border-hover: #353862;
    --accent: #6366f1;
    --accent-glow: rgba(99, 102, 241, 0.15);
    --accent-light: #818cf8;
    --accent-dim: rgba(99, 102, 241, 0.3);
    --text-primary: #e8eaf6;
    --text-secondary: #9fa3c7;
    --text-muted: #5a5e7a;
    --green: #10b981;
    --green-bg: rgba(16, 185, 129, 0.08);
    --green-border: rgba(16, 185, 129, 0.2);
    --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.4), 0 2px 6px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.5), 0 2px 6px rgba(0, 0, 0, 0.4);
    --nav-bg: rgba(13, 15, 29, 0.92);
    --nav-mobile-bg: rgba(13, 15, 29, 0.98);
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 5rem;
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  ::selection {
    background: var(--accent);
    color: #fff;
  }

  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--bg-secondary); }
  ::-webkit-scrollbar-thumb { background: var(--border-hover); border-radius: 3px; }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.4rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin-bottom: 0.875rem;
  }

  .section-subtitle {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.75;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.55rem;
    background: rgba(85, 88, 227, 0.07);
    border: 1px solid rgba(85, 88, 227, 0.18);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 1px solid transparent;
    font-family: var(--font-sans);
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--accent-light);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px var(--accent-glow);
  }

  .btn-outline {
    background: transparent;
    border-color: var(--border-hover);
    color: var(--text-secondary);
  }
  .btn-outline:hover {
    border-color: var(--accent-dim);
    color: var(--accent);
    transform: translateY(-1px);
  }
</style>
