---
const projects = [
  {
    num: '01',
    tag: 'Backend · Belvi Digital',
    name: 'Zeus',
    featured: true,
    description:
      'Mantenimiento y evolución del Core Engine de gestión IoT médico, estructurado bajo Arquitectura Hexagonal y DDD. Lideré la integración del motor de IA generativa y la automatización de reportes complejos.',
    highlights: [
      'Mantenimiento y extensión de la arquitectura de Bounded Contexts (Hermes/Shared) bajo principios de Hexagonal y DDD',
      'Evolución del sistema reactivo mediante el uso de buses de eventos asíncronos basados en RabbitMQ',
      'Implementación de nuevas funcionalidades de negocio y reportes financieros mediante patrones CQRS (Command/Query Bus)',
      'Aseguré la calidad y estabilidad de las nuevas features mediante Testing BDD (Cucumber) y Unit Testing (Jest)',
      'Optimización del flujo de entrega de requerimientos aplicando Spec-Driven Development integrado con Azure DevOps',
    ],
    stack: ['TypeScript', 'Node.js', 'Hexagonal', 'DDD', 'RabbitMQ', 'CQRS', 'Cucumber BDD', 'TypeORM', 'PostgreSQL', 'Docker'],
    note: 'Código Comercial Protegido (NDA) — Propiedad de las empresas mencionadas. Para evidenciar mi criterio de software y destreza técnica, actualmente me encuentro construyendo versiones Open-Source \'espejo\' (como mi proyecto Pliegos con la API del SECOP) disponibles próximamente en mi GitHub.',
  },
  {
    num: '02',
    tag: 'Backend · Belvi Digital',
    name: 'Plei — SmartSearch',
    featured: false,
    description:
      'Lideré el diseño y construcción del motor de búsqueda semántica (RAG) y el Core Backend de la plataforma Plei, implementando una arquitectura de base de datos dual y desacoplando la IA mediante patrones de diseño avanzados.',
    highlights: [
      'Arquitectura de base de datos híbrida: MySQL para lógica transaccional y PostgreSQL + pgvector para persistencia y búsqueda de similitud vectorial',
      'Implementación del Patrón Strategy para la abstracción de proveedores de LLM, permitiendo alternar entre Ollama y OpenAI en runtime sin modificar el dominio',
      'Pipeline de sincronización reactiva mediante el Patrón Processor y Traits, enriqueciendo y transformando modelos hacia el motor vectorial vía Jobs asíncronos',
      'Capa de seguridad vectorial: Implementación de filtros de visibilidad y jerarquía de roles directamente sobre las consultas de pgvector (VectorSearcher)',
      'Optimización de rendimiento mediante caché distribuida en Redis con tagging específico para la invalidación del motor de búsqueda',
    ],
    stack: ['PHP', 'Laravel', 'MySQL', 'PostgreSQL', 'pgvector', 'Redis', 'Strategy Pattern', 'Processor Pattern', 'Ollama', 'OpenAI', 'Docker'],
    note: 'Código Comercial Protegido (NDA) — Propiedad de las empresas mencionadas. Para evidenciar mi criterio de software y destreza técnica, actualmente me encuentro construyendo versiones Open-Source \'espejo\' (como mi proyecto Pliegos con la API del SECOP) disponibles próximamente en mi GitHub.',
  },
  {
    num: '03',
    tag: 'Backend & Dashboard · Alaska Tech',
    name: 'VeciApp',
    featured: false,
    description:
      'Desarrollo exclusivo del Core Backend (API REST) y arquitectura de base de datos para la plataforma VeciApp, además del diseño e implementación de su Dashboard administrativo web utilizando React.',
    highlights: [
      'Arquitectura de API REST con Express + TypeScript enfocada 100% en el core de negocio y gestión web',
      'Diseño e implementación de Dashboard administrativo para control total de la plataforma',
      'Chat en tiempo real vendedor–cliente con Socket.IO y persistencia',
      'Integración de pasarela de pagos con Wompi y búsqueda geoespacial con PostGIS',
    ],
    stack: ['Node.js', 'TypeScript', 'Express', 'TypeORM', 'PostgreSQL', 'React', 'Socket.IO', 'Wompi', 'Firebase', 'PostGIS'],
    link: { label: 'Ver en Play Store', href: 'https://play.google.com/store/apps/details?id=com.alaskatech.veciapp' },
    note: 'Código Comercial Protegido (NDA) — Propiedad de las empresas mencionadas. Para evidenciar mi criterio de software y destreza técnica, actualmente me encuentro construyendo versiones Open-Source \'espejo\' (como mi proyecto Pliegos con la API del SECOP) disponibles próximamente en mi GitHub.',
  },
];
---

<section class="projects-section" id="projects">
  <div class="container">
    <p class="section-label">// experiencia</p>
    <h2 class="section-title">Experiencia de Ingeniería en Producción</h2>
    <p class="section-subtitle">
      Sistemas comerciales desarrollados en empresas — arquitecturas robustas e integraciones de IA en producción.
    </p>
  </div>

  <div class="projects-scroll-outer">
    <div class="container">
      <div class="projects-list">
        {
          projects.map((p) => (
            <article class={`project-card${p.featured ? ' featured' : ''}`}>
              <div class="project-aside">
                <span class="project-num">{p.num}</span>
                <span class="project-tag">{p.tag}</span>
                {p.featured && <span class="featured-badge">✦ Destacado</span>}
              </div>
              <div class="project-body">
                <h3 class="project-name">{p.name}</h3>
                <p class="project-desc">{p.description}</p>
                <ul class="project-highlights">
                  {p.highlights.map((h) => (
                    <li>
                      <span class="arrow">→</span>
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
                {'note' in p && p.note && (
                  <p class="project-note">🔒 {p.note}</p>
                )}
                <div class="project-footer">
                  <div class="project-stack">
                    {p.stack.map((t) => <span class="badge">{t}</span>)}
                  </div>
                  {'link' in p && p.link && (
                    <a href={p.link.href} target="_blank" rel="noopener" class="project-link">
                      {p.link.label} ↗
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>


<style>
  .projects-section {
    padding: 6rem 0 0;
    background: var(--bg-secondary);
  }

  .projects-section .container {
    padding: 0 1.5rem;
  }

  .projects-scroll-outer {
    margin-top: 2.5rem;
    padding-bottom: 6rem;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: 150px 1fr;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .project-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .project-card.featured {
    border-color: rgba(85, 88, 227, 0.3);
  }
  .project-card.featured .project-aside {
    background: rgba(85, 88, 227, 0.05);
  }

  .project-aside {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 1.75rem 1.125rem;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border);
    gap: 0.625rem;
  }

  .project-num {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-muted);
    line-height: 1;
  }

  .project-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    line-height: 1.5;
  }

  .featured-badge {
    font-size: 0.62rem;
    font-family: var(--font-mono);
    color: var(--accent);
    background: rgba(85, 88, 227, 0.1);
    border: 1px solid rgba(85, 88, 227, 0.2);
    padding: 0.2rem 0.45rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .project-body {
    padding: 1.75rem;
  }

  .project-name {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.625rem;
    letter-spacing: -0.02em;
  }

  .project-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.125rem;
  }

  .project-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.375rem;
  }

  .project-highlights li {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    color: var(--text-secondary);
    font-size: 0.855rem;
    line-height: 1.6;
  }
  .project-highlights li span:last-child {
    flex: 1;
    min-width: 0;
  }

  .arrow {
    color: var(--accent);
    font-size: 0.75rem;
    flex-shrink: 0;
    margin-top: 0.22em;
    font-family: var(--font-mono);
  }

  .project-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-note {
    font-size: 0.775rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    margin-bottom: 0.875rem;
  }

  .project-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    border: 1px solid rgba(85, 88, 227, 0.3);
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s, border-color 0.15s;
  }
  .project-link:hover {
    background: rgba(85, 88, 227, 0.08);
    border-color: var(--accent);
  }


  /* Mobile: slider horizontal */
  @media (max-width: 700px) {
    .projects-section {
      padding-bottom: 0;
    }

    .projects-scroll-outer {
      padding-bottom: 0;
    }

    .projects-list {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-padding: 0 1.25rem;
      gap: 1rem;
      padding: 0.25rem 1.25rem 1.5rem;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .projects-list::-webkit-scrollbar { display: none; }

    .project-card {
      min-width: 78vw;
      max-width: 78vw;
      scroll-snap-align: start;
      flex-shrink: 0;
      grid-template-columns: 1fr;
      transform: none !important;
    }

    .project-aside {
      flex-direction: row;
      align-items: center;
      padding: 0.875rem 1.25rem;
      border-right: none;
      border-bottom: 1px solid var(--border);
      gap: 0.75rem;
    }

    .project-num { font-size: 1.5rem; }

    .projects-section .container {
      padding: 0 1.25rem;
    }
  }
</style>
