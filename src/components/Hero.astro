---
---

<section class="intro" id="intro">
  <div class="intro-bg">
    <div class="grid-pattern"></div>
    <div class="glow-orb"></div>
  </div>

  <div class="container intro-layout">
    <!-- LEFT: contenido principal -->
    <div class="intro-content">
      <div class="available-tag">
        <span class="pulse-dot"></span>
        Disponible para nuevas oportunidades
      </div>

      <h1 class="intro-name">Brayan<br />Mercado</h1>

      <div class="intro-role">
        <span class="role-line"></span>
        <span class="role-text">Backend Engineer</span>
      </div>

      <p class="intro-desc">
        Diseño y construyo sistemas backend escalables aplicando
        <strong>Arquitectura Hexagonal + DDD</strong>. Experiencia en
        pipelines de <strong>RAG / LLM en producción</strong> y automatización
        de flujos con IA.
      </p>

      <div class="intro-actions">
        <a href="#projects" class="btn btn-primary">Ver proyectos</a>
        <a href="#contact" class="btn btn-outline">Hablemos</a>
        <a href="/cv-brayan-mercado.pdf" download class="btn btn-outline">↓ Descargar CV</a>
      </div>

      <div class="intro-badges">
        <span class="badge">TypeScript · Node.js</span>
        <span class="badge">PHP · Laravel</span>
        <span class="badge">Hexagonal + DDD</span>
        <span class="badge">RAG · pgvector</span>
        <span class="badge">RabbitMQ · CQRS</span>
      </div>
    </div>

    <!-- RIGHT: perfil + stats -->
    <aside class="intro-aside">
      <div class="profile-card">
        <div class="avatar-wrap">
          <picture>
            <source srcset="/bram-profile.webp" type="image/webp" />
            <img src="/bram-profile.png" alt="Brayan Mercado" class="avatar" width="120" height="120" />
          </picture>
        </div>
        <div class="profile-info">
          <span class="profile-name">Brayan Mercado</span>
          <span class="profile-role">Backend Engineer</span>
          <span class="profile-location">Colombia · Remoto</span>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat">
          <span class="stat-num">2.5<em>años</em></span>
          <span class="stat-label">Experiencia profesional</span>
        </div>
        <div class="stat">
          <span class="stat-num">4+</span>
          <span class="stat-label">Proyectos en producción</span>
        </div>
        <div class="stat highlight">
          <span class="stat-icon">⬡</span>
          <span class="stat-label">Hexagonal Arch + DDD</span>
        </div>
        <div class="stat">
          <span class="stat-num">12+</span>
          <span class="stat-label">Tecnologías aplicadas</span>
        </div>
      </div>

      <div class="bio-card">
        <p>
          <strong>Belvi Digital</strong> — mantuve y evolucione plataformas IoT y
          e-learning en producción, integrando inteligencia artificial generativa en ambas.
          Actualmente en <strong>Alaska Tech</strong> y disponible para nuevas oportunidades.
        </p>
      </div>
    </aside>
  </div>
</section>

<style>
  .intro {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 5.5rem 1.5rem 4rem;
  }

  .intro-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(85, 88, 227, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(85, 88, 227, 0.055) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 20%, transparent 100%);
  }

  .glow-orb {
    position: absolute;
    top: 10%;
    right: 20%;
    width: 500px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(85, 88, 227, 0.08) 0%, transparent 65%);
    filter: blur(60px);
  }

  /* Layout */
  .intro-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  /* LEFT */
  .intro-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .available-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.875rem;
    background: var(--green-bg);
    border: 1px solid var(--green-border);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--green);
    margin-bottom: 2rem;
  }

  .pulse-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
    animation: pulse 2.2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.85); }
  }

  .intro-name {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    margin-bottom: 1.125rem;
  }

  .intro-role {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.625rem;
  }
  .role-line {
    display: block;
    width: 36px;
    height: 2px;
    background: var(--accent);
    flex-shrink: 0;
  }
  .role-text {
    font-family: var(--font-mono);
    font-size: clamp(0.875rem, 2vw, 1.05rem);
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .intro-desc {
    font-size: clamp(0.9rem, 1.8vw, 1.05rem);
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.8;
    margin-bottom: 2.25rem;
  }
  .intro-desc strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .intro-actions {
    display: flex;
    gap: 0.875rem;
    margin-bottom: 2.25rem;
    flex-wrap: wrap;
  }

  .intro-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* RIGHT */
  .intro-aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .profile-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.625rem 1.375rem 1.375rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
    box-shadow: var(--shadow-sm);
  }

  .avatar-wrap {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--border-hover);
    box-shadow: 0 0 0 4px rgba(85, 88, 227, 0.1);
    background: var(--bg-card);
  }
  .avatar {
    width: 120px !important;
    height: 120px !important;
    max-width: 120px !important;
    object-fit: cover;
    object-position: center top;
    transform: scale(1.05) translateY(-5%);
    transform-origin: center top;
    display: block;
    border-radius: 50%;
  }

  .profile-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    text-align: center;
  }
  .profile-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .profile-role {
    font-size: 0.8rem;
    color: var(--accent);
    font-family: var(--font-mono);
  }
  .profile-location {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .stat {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s;
  }
  .stat:hover { border-color: var(--border-hover); }

  .stat-num {
    font-size: 1.875rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .stat-num em {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-muted);
    font-style: normal;
    margin-left: 0.15rem;
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .stat.highlight {
    background: rgba(85, 88, 227, 0.05);
    border-color: rgba(85, 88, 227, 0.2);
    align-items: center;
    text-align: center;
  }
  .stat-icon {
    font-size: 1.625rem;
    color: var(--accent);
    line-height: 1;
  }
  .stat.highlight .stat-label {
    color: var(--accent);
    font-weight: 600;
  }

  .bio-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.125rem 1.25rem;
    box-shadow: var(--shadow-sm);
  }
  .bio-card p {
    font-size: 0.8375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .bio-card strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .intro-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .intro { min-height: auto; padding: 5.5rem 1.25rem 3.5rem; }
    .glow-orb { display: none; }
  }

  @media (max-width: 480px) {
    .intro-name { font-size: clamp(2.75rem, 12vw, 3.5rem); }
  }
</style>
