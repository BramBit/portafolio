---
const links = [
  { href: '#intro', label: 'Inicio' },
  { href: '#about', label: 'Sobre mí' },
  { href: '#experience', label: 'Experiencia' },
  { href: '#skills', label: 'Skills' },
  { href: '#ai-workflows', label: 'AI & Auto' },
  { href: '#projects', label: 'Proyectos' },
  { href: '#contact', label: 'Contacto' },
];
---

<nav class="nav" id="nav">
  <div class="nav-inner container">
    <a href="#" class="nav-logo">
      <span class="bracket">[</span>bm<span class="bracket">]</span>
    </a>
    <ul class="nav-links">
      {links.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
    </ul>
    <a href="#contact" class="btn btn-primary nav-cta">Contacto</a>
    <button class="theme-toggle" aria-label="Cambiar tema" id="theme-toggle">
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
    </button>
    <button class="hamburger" aria-label="Menú" id="hamburger">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="mobile-menu" id="mobile-menu">
    {links.map((link) => <a href={link.href}>{link.label}</a>)}
  </div>
</nav>

<script>
  const hamburger = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu');
  hamburger?.addEventListener('click', () => menu?.classList.toggle('open'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.remove('open')));

  const toggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;
  const root = document.documentElement;

  function syncToggleIcons() {
    const isDark = root.getAttribute('data-theme') === 'dark';
    const moon = toggle?.querySelector<SVGElement>('.icon-moon');
    const sun = toggle?.querySelector<SVGElement>('.icon-sun');
    if (!moon || !sun) return;
    moon.style.display = isDark ? 'none' : 'block';
    sun.style.display = isDark ? 'block' : 'none';
    toggle?.setAttribute('aria-label', isDark ? 'Cambiar a modo claro' : 'Cambiar a modo oscuro');
  }

  toggle?.addEventListener('click', () => {
    const isDark = root.getAttribute('data-theme') === 'dark';
    if (isDark) {
      root.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
    } else {
      root.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
    }
    syncToggleIcons();
  });

  syncToggleIcons();
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background: var(--nav-bg);
    border-bottom: 1px solid var(--border);
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .nav-inner {
    padding: 0 1.5rem;
    height: 3.75rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-right: auto;
  }
  .bracket { color: var(--accent); }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0.125rem;
  }

  .nav-links a {
    padding: 0.375rem 0.75rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-links a:hover {
    color: var(--accent);
    background: rgba(85, 88, 227, 0.06);
  }

  /* Ocultar el último link (Contacto) en desktop porque ya está el botón */
  .nav-links li:last-child {
    display: none;
  }

  .nav-cta {
    padding: 0.45rem 1rem;
    font-size: 0.8125rem;
    flex-shrink: 0;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 6px;
    background: none;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    cursor: pointer;
    flex-shrink: 0;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .theme-toggle:hover {
    border-color: var(--accent-dim);
    color: var(--accent);
    background: var(--accent-glow);
  }
  .theme-toggle svg {
    width: 1rem;
    height: 1rem;
  }
  .icon-sun { display: none; }

  .mobile-menu {
    display: none;
    flex-direction: column;
    background: var(--nav-mobile-bg);
    border-top: 1px solid var(--border);
    padding: 0.75rem 1.5rem 1rem;
    gap: 0.125rem;
    transition: background 0.3s ease;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    padding: 0.625rem 0.75rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    border-radius: 6px;
    transition: color 0.15s;
  }
  .mobile-menu a:hover { color: var(--accent); }

  @media (max-width: 680px) {
    .nav-links, .nav-cta { display: none; }
    .hamburger { display: flex; }
  }
</style>
