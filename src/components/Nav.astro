---
const links = [
  { href: '#intro', label: 'Inicio' },
  { href: '#skills', label: 'Skills' },
  { href: '#experience', label: 'Experiencia' },
  { href: '#projects', label: 'Proyectos' },
  { href: '#contact', label: 'Contacto' },
];
---

<nav class="nav" id="nav">
  <div class="nav-inner container">
    <a href="#" class="nav-logo">
      <span class="bracket">[</span>bm<span class="bracket">]</span>
    </a>
    <ul class="nav-links">
      {links.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
    </ul>
    <a href="#contact" class="btn btn-primary nav-cta">Contacto</a>
    <button class="hamburger" aria-label="Menú" id="hamburger">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="mobile-menu" id="mobile-menu">
    {links.map((link) => <a href={link.href}>{link.label}</a>)}
  </div>
</nav>

<script>
  const btn = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('open'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.remove('open')));
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background: rgba(245, 246, 255, 0.92);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    padding: 0 1.5rem;
    height: 3.75rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-right: auto;
  }
  .bracket { color: var(--accent); }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0.125rem;
  }

  .nav-links a {
    padding: 0.375rem 0.75rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-links a:hover {
    color: var(--accent);
    background: rgba(85, 88, 227, 0.06);
  }

  .nav-cta {
    padding: 0.45rem 1rem;
    font-size: 0.8125rem;
    flex-shrink: 0;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    background: rgba(245, 246, 255, 0.98);
    border-top: 1px solid var(--border);
    padding: 0.75rem 1.5rem 1rem;
    gap: 0.125rem;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    padding: 0.625rem 0.75rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    border-radius: 6px;
    transition: color 0.15s;
  }
  .mobile-menu a:hover { color: var(--accent); }

  @media (max-width: 680px) {
    .nav-links, .nav-cta { display: none; }
    .hamburger { display: flex; }
  }
</style>
